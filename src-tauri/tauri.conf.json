{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Taskbar Garden",
  "version": "0.1.0",
  "identifier": "io.github.taskbargame.garden",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Taskbar Garden",
        "width": 340,
        "height": 480,
        "minWidth": 300,
        "minHeight": 440,
        "resizable": false,
        "decorations": false,
        "transparent": false,
        "shadow": true,
        "alwaysOnTop": false,
        "skipTaskbar": true,
        "visible": false,
        "focus": true,
        "center": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'; media-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Game",
    "shortDescription": "Cozy pixel-art garden in your tray",
    "longDescription": "Plant seeds, water flowers, sell to villagers. Quiet companion that lives in your system tray."
  }
}
